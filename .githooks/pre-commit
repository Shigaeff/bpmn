#!/usr/bin/env bash
# pre-commit hook: proteção de segredos + verificação de sintaxe Python
# Gerado pelo plugin create-project

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

BLOCKED=0

# ===========================================================================
# 1. Proteção de segredos
# ===========================================================================

SECRET_PATTERNS=(
    'AKIA[0-9A-Z]{16}'
    'ghp_[0-9a-zA-Z]{36}'
    'gho_[0-9a-zA-Z]{36}'
    'ghs_[0-9a-zA-Z]{36}'
    'github_pat_[0-9a-zA-Z_]{82}'
    '-----BEGIN.*PRIVATE KEY-----'
    'sk-[0-9a-zA-Z]{48}'
    'xox[bpors]-[0-9a-zA-Z-]{10,}'
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -n "$STAGED_FILES" ]; then
    for file in $STAGED_FILES; do
        if [[ "$file" == .githooks/* ]] || [[ "$file" == .git/* ]]; then
            continue
        fi
        if ! file "$file" 2>/dev/null | grep -q "text"; then
            continue
        fi
        for pattern in "${SECRET_PATTERNS[@]}"; do
            if grep -qE "$pattern" "$file" 2>/dev/null; then
                echo -e "${RED}BLOQUEADO:${NC} Possível segredo encontrado em ${YELLOW}$file${NC}"
                echo -e "  Padrão: $pattern"
                BLOCKED=1
            fi
        done
    done
fi

# ===========================================================================
# 2. Verificação de sintaxe Python
# ===========================================================================

PYTHON_FILES=$(echo "$STAGED_FILES" | grep '\.py$' || true)

if [ -n "$PYTHON_FILES" ]; then
    for pyfile in $PYTHON_FILES; do
        if [ -f "$pyfile" ]; then
            if ! python -c "import py_compile; py_compile.compile('$pyfile', doraise=True)" 2>/dev/null; then
                echo -e "${RED}ERRO DE SINTAXE:${NC} ${YELLOW}$pyfile${NC}"
                python -c "import py_compile; py_compile.compile('$pyfile', doraise=True)" 2>&1 || true
                BLOCKED=1
            fi
        fi
    done
fi

if [ $BLOCKED -ne 0 ]; then
    echo ""
    echo -e "${RED}Commit bloqueado.${NC} Corrija os problemas acima e tente novamente."
    exit 1
fi

exit 0
